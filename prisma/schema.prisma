generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String          @id @default(cuid())
  email           String          @unique
  role            String          @default("REQUESTER")
  createdAt       DateTime        @default(now())
  profile         Profile?
  serviceRequests ServiceRequest[]
  missions        Mission[]
  bookings        Booking[]       @relation("RequesterBookings")
  reviews         Review[]
  hotlineRequests HotlineRequest[]
}

model Profile {
  id                String   @id @default(cuid())
  userId            String   @unique
  firstName         String
  lastName          String
  avatarUrl         String
  description       String
  rating            Float    @default(0)
  completedMissions Int      @default(0)
  isVerified        Boolean  @default(false)
  isTopProvider     Boolean  @default(false)
  city              String
  lat               Float
  lng               Float
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ServiceCategory {
  id              String              @id @default(cuid())
  name            String
  slug            String              @unique
  icon            String
  fromPrice       Int
  description     String
  createdAt       DateTime            @default(now())
  subcategories   ServiceSubcategory[]
  tasks           TaskItem[]
  serviceRequests ServiceRequest[]
  missions        Mission[]
}

model ServiceSubcategory {
  id          String    @id @default(cuid())
  categoryId  String
  name        String
  slug        String    @unique
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  tasks       TaskItem[]
  serviceRequests ServiceRequest[]
}

model TaskItem {
  id            String      @id @default(cuid())
  categoryId    String
  subcategoryId String
  title         String
  slug          String      @unique
  mode          String
  isFreeRequest Boolean     @default(false)
  category      ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  subcategory   ServiceSubcategory @relation(fields: [subcategoryId], references: [id], onDelete: Cascade)
  tags          TaskOnTag[]
  serviceRequests ServiceRequest[]
}

model TaskTag {
  id    String      @id @default(cuid())
  name  String
  slug  String      @unique
  tasks TaskOnTag[]
}

model TaskOnTag {
  taskId String
  tagId  String
  task   TaskItem @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag    TaskTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
}

model ServiceRequest {
  id                String    @id @default(cuid())
  userId            String?
  categoryId        String?
  subcategoryId     String?
  taskId            String?
  partnerId         String?
  status            String    @default("new")
  address           String
  city              String
  lat               Float?
  lng               Float?
  requestDate       DateTime?
  mode              String
  reservationSource String    @default("app")
  freeText          String?
  createdAt         DateTime  @default(now())
  user              User?     @relation(fields: [userId], references: [id])
  category          ServiceCategory? @relation(fields: [categoryId], references: [id])
  subcategory       ServiceSubcategory? @relation(fields: [subcategoryId], references: [id])
  task              TaskItem? @relation(fields: [taskId], references: [id])
  partner           Partner?  @relation(fields: [partnerId], references: [id])
}

model Mission {
  id               String    @id @default(cuid())
  providerId       String
  categoryId       String
  title            String
  description      String
  fromPrice        Int
  currency         String    @default("CHF")
  isAvailableToday Boolean   @default(true)
  distanceKm       Float
  badge            String?
  status           String    @default("active")
  lat              Float
  lng              Float
  calendarJson     String
  createdAt        DateTime  @default(now())
  provider         User      @relation(fields: [providerId], references: [id], onDelete: Cascade)
  category         ServiceCategory @relation(fields: [categoryId], references: [id])
  bookings         Booking[]
  reviews          Review[]
}

model Booking {
  id                String    @id @default(cuid())
  requesterId       String?
  missionId         String?
  parkingListingId  String?
  partnerId         String?
  serviceType       String
  reservationSource String    @default("app")
  status            String    @default("pending")
  startAt           DateTime
  endAt             DateTime
  totalFromPrice    Int
  createdAt         DateTime  @default(now())
  requester         User?     @relation("RequesterBookings", fields: [requesterId], references: [id])
  mission           Mission?  @relation(fields: [missionId], references: [id])
  parkingListing    ParkingListing? @relation(fields: [parkingListingId], references: [id])
  partner           Partner?  @relation(fields: [partnerId], references: [id])
  payment           Payment?
  review            Review?
}

model Review {
  id          String    @id @default(cuid())
  bookingId   String    @unique
  missionId   String?
  reviewerId  String?
  rating      Int
  comment     String?
  isPublic    Boolean   @default(true)
  isModerated Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  booking     Booking   @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  mission     Mission?  @relation(fields: [missionId], references: [id])
  reviewer    User?     @relation(fields: [reviewerId], references: [id])
}

model Payment {
  id                String   @id @default(cuid())
  bookingId         String   @unique
  amount            Int
  currency          String   @default("CHF")
  providerReleaseAt DateTime?
  method            String
  status            String   @default("pending")
  createdAt         DateTime @default(now())
  booking           Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
}

model ParkingListing {
  id            String    @id @default(cuid())
  ownerName     String
  title         String
  address       String
  city          String
  dayPrice      Int
  nightPrice    Int
  employeePrice Int
  campingPrice  Int
  hasPower      Boolean   @default(false)
  isAvailable   Boolean   @default(true)
  lat           Float
  lng           Float
  createdAt     DateTime  @default(now())
  bookings      Booking[]
}

model Partner {
  id             String    @id @default(cuid())
  name           String
  type           String
  address        String
  city           String
  lat            Float
  lng            Float
  commissionRate Float     @default(5)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  serviceRequests ServiceRequest[]
  bookings       Booking[]
}

model HotlineRequest {
  id            String   @id @default(cuid())
  userId        String?
  firstName     String
  lastName      String
  phone         String
  city          String
  serviceType   String
  preferredTime String
  notes         String?
  status        String   @default("new")
  source        String   @default("web")
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])
}

model CallRequest {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  status        String   @default("new")
  firstName     String
  lastName      String
  phone         String
  city          String
  category      String
  preferredSlot String
  contactMode   String
  note          String?
  consent       Boolean
  source        String   @default("web")
}
